{
  "name": "k65t",
  "version": "0.1.0",
  "type": "module",
  "description": "K65.t assembler for 6502",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node --enable-source-maps node_modules/tap/bin/tap.js test/**/*.test.ts",
    "convert": "node --enable-source-maps dist/MACRO-10-Converter/convert.js test/M6502.asm test/m6502.converted.asm",
    "converted": "node --enable-source-maps dist/Assembler/index.js test/m6502.converted.asm"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/tap": "^18.0.4",
    "eslint": "^9.0.0",
    "prettier": "^3.1.1",
    "tap": "^18.6.1",
    "typescript": "^5.3.3"
  }
}
