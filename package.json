{
  "name": "k65t",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "6502 multi-pass macro assembler written in TypeScript/Node.js.",
  "keywords": [
    "6502",
    "assembler",
    "macro",
    "typescript",
    "node"
  ],
  "license": "MIT",
  "author": "Kai Henningsen <kai.extern@gmail.com>",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "convert": "node --enable-source-maps dist/MACRO-10-Converter/convert.js test/m6502.asm test/m6502.converted.asm",
    "converted": "node --enable-source-maps dist/Assembler/index.js test/m6502.converted.asm",
    "start": "node --enable-source-maps dist/Assembler/index.js",
    "test": "node --enable-source-maps --test dist/**/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
