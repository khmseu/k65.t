{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "VersionLens: NPM Install",
      "command": "npm",
      "type": "shell",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Assemble and Run Test File",
      "command": "npm",
      "type": "shell",
      "args": [
        "start",
        "--",
        "./test/m6502_k65.asm"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "dependsOn": "npm: build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": [],
      "label": "npm: build",
      "detail": "tsc -p tsconfig.json ",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      }
    },
    {
      "type": "npm",
      "script": "convert",
      "problemMatcher": [],
      "label": "npm: convert",
      "detail": "node --enable-source-maps dist/MACRO-10-Converter/convert.js"
    },
    {
      "type": "npm",
      "script": "converted",
      "problemMatcher": [],
      "label": "npm: converted",
      "detail": "node --enable-source-maps dist/Assembler/index.js test/m6502.converted.asm"
    }
  ]
}