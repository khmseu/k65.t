{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "VersionLens: NPM Install",
            "command": "npm",
            "type": "shell",
            "args": [
                "install"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "presentation": {
